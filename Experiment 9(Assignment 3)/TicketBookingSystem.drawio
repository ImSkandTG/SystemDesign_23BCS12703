        <mxCell id="i8PK6XX_c-FSgPfPt5eC-111" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="User Service" vertex="1">
          <mxGeometry height="30" width="110" x="549" y="110" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-112" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="User DB" vertex="1">
          <mxGeometry height="30" width="60" x="725" y="120.33" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-115" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Functional Requirement:&lt;/b&gt;" vertex="1">
          <mxGeometry height="50" width="305" x="77.61" y="-750" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-116" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;b&gt;Search Functionality:&lt;/b&gt; The user must be able to discover events using filters such as the Event Title, the City/Location, and the specific Date of the show.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="860" x="145" y="-710" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-117" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;b&gt;Event Information Display:&lt;/b&gt; The user must be able to view comprehensive details for a specific event, including the No of Seats (available vs. occupied), a detailed Description, and Metadata (cast, duration, language, ratings).&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="770" x="160" y="-670" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-118" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Booking Execution:&lt;/b&gt;&amp;nbsp;The system must allow a user to select a seat and complete a transaction to Book a Ticket." vertex="1">
          <mxGeometry height="30" width="710" x="110" y="-700" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-119" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Target Scale:&lt;/b&gt; The system must be designed to support 100 Million Daily Active Users (DAU)." vertex="1">
          <mxGeometry height="30" width="520" x="170" y="-560" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-120" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;High Availability:&lt;/b&gt; When users are searching or viewing an event, the system must prioritize being &quot;always online&quot; (High Availability). It is better to show slightly older data than to show an error page." vertex="1">
          <mxGeometry height="30" width="1090" x="160" y="-530" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-121" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;High Consistency:&lt;/b&gt; When a user is booking a specific ticket, the system must be Highly Consistent. Two people should never be able to book the exact same seat at the exact same time." vertex="1">
          <mxGeometry height="30" width="1010" x="170" y="-500" as="geometry" />
        </mxCell>
        <mxCell id="i8PK6XX_c-FSgPfPt5eC-122" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Non-Functional Requirements:&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="430" x="40" y="-590" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
